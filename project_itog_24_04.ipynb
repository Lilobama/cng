        "!pip install -q python-telegram-bot --upgrade\n",
        "\n",
        "# 2. Все импорты\n",
        "import tempfile
        "import logging
        "import asyncio
        "import nest_asyncio

        "import numpy as np
        "import pandas as pd
        "import joblib

        "from telegram import Update, ReplyKeyboardMarkup, KeyboardButton, InlineKeyboardMarkup, InlineKeyboardButton
        "from telegram.ext import (
        "    ApplicationBuilder,
        "    CommandHandler,
        "    MessageHandler,
        "    CallbackQueryHandler,
        "    ContextTypes,
        "    filters,
        ")


        "import librosa as lb
        "import soundfile as sf
        "import os
        "\n",
        "nest_asyncio.apply()\n",
        "logging.basicConfig(level=logging.INFO)\n",
        "\n",
        "async def handle_audio(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    user_id = update.effective_user.id\n",
        "    if not context.user_data.get('awaiting_audio'):\n",
        "        await update.message.reply_text(\"ℹ️ Сначала нажмите «Определить жанр трека».\")\n",
        "        return\n",
        "    context.user_data['awaiting_audio'] = False\n",
        "\n",
        "    if update.message.audio:\n",
        "        file_obj, file_type, suffix = update.message.audio, \"аудио\", \".mp3\"\n",
        "    elif update.message.voice:\n",
        "        file_obj, file_type, suffix = update.message.voice, \"голосовое\", \".ogg\"\n",
        "    else:\n",
        "        return\n",
        "\n",
        "    required = ['md', 'sc', 'le', 'fc', 'Music']\n",
        "    if any(name not in globals() for name in required):\n",
        "        await update.message.reply_text(\"⚠️ Модель не загружена.\")\n",
        "        return\n",
        "\n",
        "    if file_obj.file_size > 20 * 1024 * 1024:\n",
        "        await update.message.reply_text(f\"❌ Файл больше 20 МБ.\")\n",
        "        return\n",
        "\n",
        "    msg = await update.message.reply_text(f\"🎵 Анализирую {file_type}...\")\n",
        "    tmp_path = None\n",
        "    try:\n",
        "        tg_file = await file_obj.get_file()\n",
        "        with tempfile.NamedTemporaryFile(suffix=suffix, delete=False) as f:\n",
        "            tmp_path = f.name\n",
        "            await tg_file.download_to_drive(tmp_path)\n",
        "\n",
        "        def process():\n",
        "            track = Music(tmp_path)\n",
        "            track.load_and_process()\n",
        "            feats = track.get_features(fc)\n",
        "            feats_df = pd.DataFrame([feats], columns=fc)\n",
        "            feats_scaled = sc.transform(feats_df)\n",
        "            pred = md.predict(feats_scaled)[0]\n",
        "            proba = md.predict_proba(feats_scaled)[0]\n",
        "            return pred, proba\n",
        "\n",
        "        pred, proba = await asyncio.wait_for(asyncio.to_thread(process), timeout=60.0)\n",
        "        genre = le.inverse_transform([pred])[0]\n",
        "        conf = np.max(proba) * 100\n",
        "\n",
        "\n",
        "        all_probs = \"\"\n",
        "        for i, g in enumerate(le.classes_):\n",
        "            all_probs += f\"{g}: {proba[i]*100:.2f}%\\n\"\n",
        "\n",
        "\n",
        "        resp = f\"🎶 Результат: {genre}\\n📊 Уверенность: {conf:.2f}%\\n\\n\"\n",
        "        resp += \"Вероятности по всем жанрам:\\n\"\n",
        "        resp += all_probs\n",
        "\n",
        "        await update.message.reply_text(resp)\n",
        "    except asyncio.TimeoutError:\n",
        "        await update.message.reply_text(\"⏰ Анализ занял слишком много времени.\")\n",
        "    except Exception as e:\n",
        "        logging.error(f\"Error {user_id}: {e}\", exc_info=True)\n",
        "        await update.message.reply_text(f\"❌ Ошибка: {e}\")\n",
        "    finally:\n",
        "        if tmp_path and os.path.exists(tmp_path):\n",
        "            os.remove(tmp_path)\n",
        "        try:\n",
        "            await msg.delete()\n",
        "        except:\n",
        "            pass\n",
        "\n",
        "async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    await update.message.reply_text(\"Бот-классификатор жанров. Введите /menu или /help\")\n",
        "\n",
        "async def help_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    await update.message.reply_text(\"Команды: /start /help /about /question /menu\")\n",
        "\n",
        "async def about(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    await update.message.reply_text(\"Жанры: Blues, Classical, Country, Disco, Hip-hop, Jazz, Metal, Pop, Reggae, Rock. Связь: @lilobeme\")\n",
        "\n",
        "async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    text = update.message.text\n",
        "    if \"Определить жанр трека\" in text:\n",
        "        context.user_data['awaiting_audio'] = True\n",
        "        await update.message.reply_text(\"🎧 Отправьте аудиофайл.\")\n",
        "    elif text == '/help':\n",
        "        await help_cmd(update, context)\n",
        "    elif text.lower() == 'привет':\n",
        "        await update.message.reply_text('💋')\n",
        "    elif text == 'О боте':\n",
        "        await about(update, context)\n",
        "    else:\n",
        "        await update.message.reply_text(\"...\")\n",
        "\n",
        "async def question(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    kb = [[InlineKeyboardButton(\"Мне нравится\", callback_data=\"yes\"),\n",
        "           InlineKeyboardButton(\"Плохой бот\", callback_data=\"no\")]]\n",
        "    await update.message.reply_text(\"Ваше мнение о боте?\", reply_markup=InlineKeyboardMarkup(kb))\n",
        "\n",
        "async def callback(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    q = update.callback_query\n",
        "    await q.answer()\n",
        "    text = \"Спасибо, мы рады! 😊\" if q.data == \"yes\" else \"Будем улучшать 🥹\" if q.data == \"no\" else \"...\"\n",
        "    await q.edit_message_text(text)\n",
        "\n",
        "async def menu(update: Update, context: ContextTypes.DEFAULT_TYPE):\n",
        "    kb = ReplyKeyboardMarkup([[KeyboardButton(\"Определить жанр трека\"), KeyboardButton(\"/help\")]], resize_keyboard=True)\n",
        "    await update.message.reply_text(\"Выберите:\", reply_markup=kb)\n",
        "\n",
        "app = ApplicationBuilder().token(BOT_TOKEN).build()\n",
        "app.add_handler(CommandHandler(\"start\", start))\n",
        "app.add_handler(CommandHandler(\"help\", help_cmd))\n",
        "app.add_handler(CommandHandler(\"about\", about))\n",
        "app.add_handler(CommandHandler(\"menu\", menu))\n",
        "app.add_handler(CommandHandler(\"question\", question))\n",
        "app.add_handler(CallbackQueryHandler(callback))\n",
        "app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))\n",
        "app.add_handler(MessageHandler(filters.AUDIO | filters.VOICE, handle_audio))"
